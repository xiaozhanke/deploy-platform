# WebSocket(STOMP) 经 vite 升级代理（见 vite.config.ts 的 /websocket，ws:true）；
# 前端用同源 wss://<host>/websocket，由 getWebSocketUrl() 按页面协议推导，无需显式 VITE_WEBSOCKET_URL。
VITE_OIDC_AUTHORITY=https://localhost:5173
VITE_OIDC_CLIENT_ID=oidc-client
VITE_OIDC_REDIRECT_URI=https://localhost:5173/ui/login/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://localhost:5173/ui/login/landing
VITE_OIDC_SCOPE="openid profile"