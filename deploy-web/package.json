    "npm-run-all2": "^7.0.2",
    "prettier": "3.5.3",
    "sass": "^1.86.0",
    "typescript": "~5.8.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.3.3",
