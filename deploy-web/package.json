    "@element-plus/icons-vue": "^2.3.1",
    "@stomp/stompjs": "^7.1.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "axios": "^1.8.4",
    "codemirror": "^6.0.1",
    "dayjs": "^1.11.13",
    "element-plus": "^2.11.3",
    "oidc-client-ts": "^3.2.1",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.5.0"
