# 生产 OIDC 配置
# 必须是绝对 URL，且与后端 application-pro.yml 的 redirect-uris / post-logout-redirect-uris
# 精确字符串匹配（相对路径会被 Spring AS 拒绝）。部署时把 https://deploy.example.com
# 替换为真实域名（需与后端 APP_BASE_URL 保持一致）。
VITE_OIDC_AUTHORITY=https://deploy.example.com
VITE_OIDC_CLIENT_ID=oidc-client
VITE_OIDC_REDIRECT_URI=https://deploy.example.com/ui/login/callback
# 登出落地页：必须指向 /ui/login/landing（落地路由），不能是 /ui/login（会被重定向进回调死循环）
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://deploy.example.com/ui/login/landing
VITE_OIDC_SCOPE="openid profile"
